# ── STRIPE ──────────────────────────────────────────
# Get these from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a recurring £4/month product in Stripe, paste the Price ID here
STRIPE_PRICE_ID=price_...

# ── APP ─────────────────────────────────────────────
PORT=3000
# Your live domain (no trailing slash). Used for Stripe redirect URLs.
BASE_URL=http://localhost:3000

# ── EMAIL (SMTP) ─────────────────────────────────────
# Use any SMTP provider: Gmail, Brevo, Resend, Mailgun, etc.
# Gmail example: enable App Passwords in your Google account settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=QUID <no-reply@quid.co.uk>

# ── ADMIN ────────────────────────────────────────────
# Secret key for protected admin endpoints
ADMIN_KEY=change-me-to-something-secret
